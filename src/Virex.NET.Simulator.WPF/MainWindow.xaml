<Window x:Class="Virex.NET.Simulator.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Virex.NET Integration Simulator"
        Width="1040"
        Height="720"
        MinWidth="900"
        MinHeight="620">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <TextBlock Text="Virex.NET Integration Simulator"
               FontSize="22"
               FontWeight="SemiBold"
               Margin="0,0,0,12" />

    <Grid Grid.Row="1" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*" />
        <ColumnDefinition Width="2*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <GroupBox Header="Connection Settings" Padding="12" Margin="0,0,12,0">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Text="REST prefix" VerticalAlignment="Center" />
          <TextBox x:Name="RestPrefixBox" Grid.Column="1" Text="http://127.0.0.1:5088/" Margin="0,2" />

          <TextBlock Grid.Row="1" Text="TCP port" VerticalAlignment="Center" />
          <TextBox x:Name="TcpPortBox" Grid.Row="1" Grid.Column="1" Text="5089" Margin="0,2" />

          <TextBlock Grid.Row="2" Text="MQTT host" VerticalAlignment="Center" />
          <TextBox x:Name="MqttHostBox" Grid.Row="2" Grid.Column="1" Text="127.0.0.1" Margin="0,2" />

          <TextBlock Grid.Row="3" Text="MQTT port/topic" VerticalAlignment="Center" />
          <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,2">
            <TextBox x:Name="MqttPortBox" Text="1883" Width="80" Margin="0,0,8,0" />
            <TextBox x:Name="MqttTopicBox" Text="virex" Width="180" />
          </StackPanel>

          <TextBlock Grid.Row="4" Text="Result prefix" VerticalAlignment="Center" />
          <TextBox x:Name="ResultPrefixBox" Grid.Row="4" Grid.Column="1" Text="" Margin="0,2" />
        </Grid>
      </GroupBox>

      <GroupBox Grid.Column="1" Header="ProductInfo" Padding="12" Margin="0,0,12,0">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="95" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Text="Lot ID" VerticalAlignment="Center" />
          <TextBox x:Name="LotIDBox" Grid.Column="1" Text="LOT-001" Margin="0,2" />
          <TextBlock Grid.Row="1" Text="Wafer ID" VerticalAlignment="Center" />
          <TextBox x:Name="WaferIDBox" Grid.Row="1" Grid.Column="1" Text="W01" Margin="0,2" />
          <TextBlock Grid.Row="2" Text="Recipe" VerticalAlignment="Center" />
          <TextBox x:Name="RecipeBox" Grid.Row="2" Grid.Column="1" Text="RCP-A" Margin="0,2" />
          <TextBlock Grid.Row="3" Text="Slot" VerticalAlignment="Center" />
          <TextBox x:Name="SlotBox" Grid.Row="3" Grid.Column="1" Text="1" Margin="0,2" />
          <TextBlock Grid.Row="4" Text="Foup ID" VerticalAlignment="Center" />
          <TextBox x:Name="FoupIDBox" Grid.Row="4" Grid.Column="1" Text="FOUP-A" Margin="0,2" />
          <TextBlock Grid.Row="5" Text="Chamber ID" VerticalAlignment="Center" />
          <TextBox x:Name="ChamberIDBox" Grid.Row="5" Grid.Column="1" Text="CH-1" Margin="0,2" />
          <Button Grid.Row="6" Grid.Column="1" Content="Apply ProductInfo" Click="ApplyProductInfo_Click" Margin="0,8,0,0" />
        </Grid>
      </GroupBox>

      <GroupBox Grid.Column="2" Header="State" Padding="12">
        <StackPanel>
          <TextBlock x:Name="StatusText" Text="state=Uninitialized" Margin="0,0,0,10" TextWrapping="Wrap" />
          <Button Content="Start Servers" Click="StartServers_Click" Margin="0,0,0,6" />
          <Button Content="Stop Servers" Click="StopServers_Click" Margin="0,0,0,12" />
          <Button Content="Initialize" Click="Initialize_Click" Margin="0,0,0,6" />
          <Button Content="Deinitialize" Click="Deinitialize_Click" Margin="0,0,0,6" />
          <Button Content="Start Cycle" Click="StartCycle_Click" Margin="0,0,0,6" />
          <Button Content="Stop" Click="Stop_Click" Margin="0,0,0,6" />
        </StackPanel>
      </GroupBox>
    </Grid>

    <GroupBox Grid.Row="2" Header="Event Log" Padding="8">
      <TextBox x:Name="LogBox"
               FontFamily="Consolas"
               FontSize="12"
               IsReadOnly="True"
               AcceptsReturn="True"
               VerticalScrollBarVisibility="Auto"
               HorizontalScrollBarVisibility="Auto" />
    </GroupBox>
  </Grid>
</Window>
